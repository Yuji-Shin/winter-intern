def load_intent_bank(path: str):
    with open(path, "r", encoding="utf-8") as f:
        return json.load(f)


def tcp_connectable(host: str, port: int, timeout_s: float = 1.5) -> bool:
    try:
        with socket.create_connection((host, port), timeout=timeout_s):
            return True
    except Exception:
        return False


def has_keyword(text: str, keywords) -> bool:
    t = text.lower()
    for k in keywords:
        if re.search(rf"\b{re.escape(k)}\b", t):
            return True
    return False


def override_safety(text: str) -> Optional[str]:
    t = text.lower()

    # 초저지연 PAIN
    if has_keyword(t, PAIN_KEYWORDS):
        return "PAIN"

    if has_keyword(t, STOP_KEYWORDS):
        return "STOP"
    if has_keyword(t, DISARM_KEYWORDS):
        return "DISARM"
    if has_keyword(t, START_KEYWORDS):
        return "START"

    return None


def extract_distance_m_clamped(text: str, default_m: float, max_step_m: float) -> float:
    """
    거리 추출(mm/cm/m) + 0~max_step_m clamp
    """
    t = text.lower()

    m = re.search(r"(\d+(\.\d+)?)\s*(mm|millimeter|millimeters)\b", t)
    if m:
        val = float(m.group(1)) / 1000.0
        return float(np.clip(val, 0.0, max_step_m))

    m = re.search(r"(\d+(\.\d+)?)\s*(cm|centimeter|centimeters)\b", t)
    if m:
        val = float(m.group(1)) / 100.0
        return float(np.clip(val, 0.0, max_step_m))

    m = re.search(r"(\d+(\.\d+)?)\s*(m|meter|meters)\b", t)
    if m:
        val = float(m.group(1))
        return float(np.clip(val, 0.0, max_step_m))

    return float(np.clip(default_m, 0.0, max_step_m))


def parse_move_command(
    text: str,
    default_step_m: float,
    max_step_m: float,
    require_move_verb: bool = True,
) -> Optional[Tuple[float, float, float, str, float]]:
    """
    "move up 5 cm" 같은 규칙 기반 이동 명령 파싱.
    성공하면 (dx,dy,dz, found_dir, dist_m) 반환, 아니면 None.
    """
    t = text.lower()

    found_dir = None
    for w in DIR_WORDS.keys():
        if re.search(rf"\b{re.escape(w)}\b", t):
            found_dir = w
            break
    if not found_dir:
        return None

    if require_move_verb:
        has_move_verb = any(re.search(rf"\b{re.escape(v)}\b", t) for v in MOVE_VERBS)
        if not has_move_verb:
            return None

    axis, sign = DIR_WORDS[found_dir]
    dist_m = extract_distance_m_clamped(t, default_m=default_step_m, max_step_m=max_step_m)

    dx = dy = dz = 0.0
    if axis == "x":
        dx = sign * dist_m
    elif axis == "y":
        dy = sign * dist_m
    else:
        dz = sign * dist_m

    return dx, dy, dz, found_dir, dist_m


def clamp_pose_xyz(pose, xyz_limits):
    pose[0] = float(np.clip(pose[0], xyz_limits["x"][0], xyz_limits["x"][1]))
    pose[1] = float(np.clip(pose[1], xyz_limits["y"][0], xyz_limits["y"][1]))
    pose[2] = float(np.clip(pose[2], xyz_limits["z"][0], xyz_limits["z"][1]))
    return pose


def safe_stop(rtde_c) -> bool:
    try:
        rtde_c.stopL(2.0)
        return True
    except Exception:
        try:
            rtde_c.stopJ(2.0)
            return True
        except Exception:
            return False


def moveL_delta(rtde_c, rtde_r, dx, dy, dz, speed, acc, xyz_limits, dry_run: bool):
    pose = rtde_r.getActualTCPPose()
    print("current TCP pose:", pose)

    target = pose.copy()
    target[0] += float(dx)
    target[1] += float(dy)
    target[2] += float(dz)
    target = clamp_pose_xyz(target, xyz_limits)

    print("target  TCP pose:", target)

    if dry_run:
        print("[DRY_RUN] skip moveL")
        return True

    ok = rtde_c.moveL(target, speed, acc)
    return ok


def handle_intent(
    intent: str,
    rtde_c,
    rtde_r,
    state,
    base_speed,
    base_acc,
    pain_retract_z_m,
    xyz_limits,
    dry_run,
    announce: Optional[Callable[[str], None]] = None,
):
    """
    intent -> 로봇 동작/상태 변경
    state: dict (armed, speed_scale, pending_move...)
    announce: TTS/briefing 안내 함수(없으면 None)
    """
    intent = (intent or "").upper()

    if intent in ("STOP", "DISARM"):
        print("[INTENT] STOP/DISARM -> stopping + disarming")
        safe_stop(rtde_c)
        state["armed"] = False
        state["pending_move"] = None
        if announce:
            announce("Stopping. Disarmed.")
        return

    if intent == "START":
        state["armed"] = True
        print("[INTENT] START -> ARMED=True")
        if announce:
            announce("Armed. Ready.")
        return

    if intent == "PAIN":
        print("[INTENT] PAIN -> stop + retract(up) + disarm")
        if announce:
            announce("Stopping. Retracting. Disarming.")
        safe_stop(rtde_c)
        time.sleep(0.1)

        retract_speed = base_speed * 0.5
        retract_acc = base_acc * 0.5
        ok = moveL_delta(
            rtde_c, rtde_r,
            0.0, 0.0, +pain_retract_z_m,
            retract_speed, retract_acc,
            xyz_limits, dry_run
        )
        print("retract ok:", ok)

        state["armed"] = False
        state["pending_move"] = None
        return

    if intent == "MOVE_SLOW":
        state["speed_scale"] = 0.5
        print("[INTENT] MOVE_SLOW -> speed_scale=0.5")
        if announce:
            announce("Slower speed.")
        return

    if intent == "OK":
        state["speed_scale"] = 1.0
        print("[INTENT] OK -> speed_scale=1.0")
        if announce:
            announce("Normal speed.")
        return

    if intent == "EXPLAIN":
        print("[INTENT] EXPLAIN -> (print) I am moving the tool based on your commands.")
        if announce:
            announce("I will move the tool based on your commands.")
        return

    print("[INTENT] Unknown/Unhandled:", intent)


def top3_str(candidates):
    try:
        return " | ".join([f"{c['intent']}:{c['score']:.3f}" for c in candidates[:3]])
    except Exception:
        return ""


def make_rtde_control(host: str, use_urcap: bool):
    """
    환경에 따라 flags 인자가 없을 수도 있어서 안전하게 생성.
    """
    if use_urcap and hasattr(rtde_control, "FLAG_USE_EXT_UR_CAP"):
        return rtde_control.RTDEControlInterface(host, flags=rtde_control.FLAG_USE_EXT_UR_CAP)
    return rtde_control.RTDEControlInterface(host)


