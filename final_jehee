STOP_KEYWORDS = ["stop", "pause", "hold on", "wait", "halt", "freeze", "emergency stop", "e stop"]
START_KEYWORDS = ["start", "begin", "resume", "arm", "enable"]   # delete "go", "continue"
DISARM_KEYWORDS = ["disarm", "disable", "cancel", "stand down"]

#(Optional) PAIN keyword override (ultra-low latency)
PAIN_KEYWORDS = ["it hurts", "hurt", "pain", "ouch"]

CONFIRM_YES = ["yes", "confirm", "execute", "do it", "okay", "ok"]
CONFIRM_NO = ["no", "cancel", "stop", "abort", "never mind"]

MOVE_VERBS = ["move", "go", "shift", "translate", "slide"] # Verbs considered as movement commands.

DIR_WORDS = {                 # Direction word -> (axis, sign).
    "up": ("z", +1),          # "up" maps to +z 1cm
    "down": ("z", -1),        # "down" maps to -z 1cm
    "left": ("y", +1),        # "left" maps to +y 1cm (based on your coordinate convention).
    "right": ("y", -1),       # "right" maps to -y 1cm.
    "forward": ("x", +1),     # "forward" maps to +x 1cm.
    "back": ("x", -1),        # "back" maps to -x 1cm.
    "backward": ("x", -1),    # "backward" is same as "back".
}


