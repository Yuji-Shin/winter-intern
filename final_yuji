# ======================
# CSV Metrics Logger
# ======================
def _now_iso():
    return datetime.now().isoformat(timespec="milliseconds") # Return current timestamp in ISO format with milliseconds.


class MetricsCSV:
    def __init__(self, path: str):
        os.makedirs(os.path.dirname(path) or ".", exist_ok=True) # Create directory for the CSV file if it doesn't exist.
        self.path = path                                         # Save the path.
        self.f = open(path, "w", newline="", encoding="utf-8")   # Open CSV file for writing.
        self.fields = [                                          # Define CSV columns.
            "ts",                                                # Timestamp (ISO).
            "kind",          # startup / utterance               # Log type.
            "step",          # load_whisper, init_minilm, route, moveL... # Which pipeline step.
            "utt_id",                                            # Utterance ID.
            "duration_ms",                                       # Total step duration [ms].
            "asr_ms",                                            # Whisper transcription time [ms].
            "text",                                              # Recognized text.
            "override_intent",                                   # Rule-based override intent (STOP/START/PAIN).
            "chosen_intent",                                     # Final selected intent.
            "chosen_score",                                      # Similarity score for chosen intent.
            "top3",                                              # Top-3 intent candidates (serialized).
            "note",                                              # Extra notes.
        ]
        self.w = csv.DictWriter(self.f, fieldnames=self.fields)  # Writer that writes dict rows to CSV.
        self.w.writeheader()                                     # Write header row.
        self.f.flush()                                           # Flush to disk.



    def log(self, **row):
        base = {k: "" for k in self.fields}                      # Initialize all fields as empty strings.
        base.update(row)                                         # Fill with provided values.
        base["ts"] = base["ts"] or _now_iso()                    # Auto-fill ts if missing.
        self.w.writerow(base)                                    # Write one CSV row.
        self.f.flush()                                           # Flush immediately. Flush means forcing the buffered data to be written to the file (disk) immediately.

    def close(self):
        try:
            self.f.close()                                       # Close the file.
        except Exception:
            pass                                                 # Ignore close errors.


# ======================
# Realtime Whisper helper
# ======================
class RealtimeWhisper:
    """
    Continuously captures mic audio,
    segments it into utterances using an energy threshold,
    and yields Whisper-transcribed text (utterance-level, not token streaming).
    """
    def __init__(self, asr_model, sample_rate=16000, input_device=None):
        self.asr = asr_model                 # Whisper model instance.
        self.sr = sample_rate                # Sample rate [Hz].
        self.device = input_device           # Input device index.

        self.q = queue.Queue()               # Queue for audio chunks.
        self.stop_event = threading.Event()  # Stop flag.

        self.chunk_frames = int(self.sr * (CHUNK_MS / 1000.0))    # Frames per chunk = sr [samples/s] * chunk_seconds.
        self.min_speech_frames = int(self.sr * MIN_SPEECH_SEC)    # Minimum utterance length in frames.
        self.end_silence_frames = int(self.sr * END_SILENCE_SEC)  # Silence threshold in frames to end an utterance.
        self.max_utt_frames = int(self.sr * MAX_UTT_SEC)          # Maximum utterance length in frames.

        self._stream: Optional[sd.InputStream] = None             # sounddevice InputStream handle.
        self._muted = threading.Event()                           # If set, callback discards input (soft mute).
        self._io_lock = threading.Lock()                          # Prevent concurrent stop/start operations.

        # last utterance ASR time (ms)
        self.last_asr_ms = 0.0    # Last ASR duration [ms].

    def _audio_cb(self, indata, frames, time_info, status):
        if status:
            print("[AUDIO]", status)     # Print audio driver warnings (overrun/underrun).
        if self._muted.is_set():
            return                       # If muted, ignore input.
        self.q.put(indata[:, 0].copy())  # Push mono channel (copy) into queue.

    def start(self):
        self.stop_event.clear()          # Clear stop flag.
        self._stream = sd.InputStream(
            samplerate=self.sr,          # Sample rate [Hz].
            channels=1,                  # Mono.
            dtype="float32",             # float32 PCM (usually ~[-1, +1]).
            blocksize=self.chunk_frames, # Callback block size in frames.
            device=self.device,          # Device index.
            callback=self._audio_cb,     # Audio callback function.
        )
        self._stream.start()             # Start capturing mic input.

    def stop(self):
        self.stop_event.set()            # Set stop flag.
        with self._io_lock:
            if self._stream:
                try:
                    self._stream.stop()  # Stop the stream.
                except Exception:
                    pass
                try:
                    self._stream.close() # Release audio resources.
                except Exception:
                    pass
                self._stream = None      # Remove handle.

    def set_muted(self, muted: bool):
        if muted:
            self._muted.set()            # Enable mute.
            self.clear_queue()           # Drop any buffered audio (avoid self-voice leakage).
        else:
            self._muted.clear()          # Disable mute.
            self.clear_queue()           # Also clear queue on resume.

    def clear_queue(self):
        try:
            while True:
                self.q.get_nowait()      # Drain the queue.
        except queue.Empty:
            pass

  
    def pause_input_stream(self):
        with self._io_lock:
            self.set_muted(True)         # Soft mute + queue clear.
            if self._stream:
                try:
                    self._stream.stop()  # Hard stop the input stream (most reliable).
                except Exception:
                    pass
            self.clear_queue()           # Drain leftover chunks.

    def resume_input_stream(self):
        with self._io_lock:
            if self._stream and not self.stop_event.is_set():
                try:
                    self._stream.start()  # Restart input stream.
                except Exception as e:
                    print("[AUDIO] resume failed:", repr(e))
            self.clear_queue()            # Clear post-restart residues.
            self.set_muted(False)         # Unmute.

    def listen_texts(self):
        in_speech = False                        # Are we currently inside an utterance?
        utt = np.zeros((0,), dtype=np.float32)   # Buffer for the current utterance audio.
        silence = 0                              # Accumulated silence (frames).

        while not self.stop_event.is_set():
            try:
                chunk = self.q.get(timeout=0.2)  # Wait up to 0.2 s for audio.
            except queue.Empty:
                continue

            rms = float(np.sqrt(np.mean(chunk * chunk) + 1e-12)) # Compute RMS energy (unitless). 1e-12 avoids numerical issues.
            if DEBUG_ENERGY:
                print(f"[RMS] {rms:.5f}")                        # Print RMS for tuning.

            is_speech = rms > ENERGY_THRESHOLD                   # Speech if RMS exceeds threshold.

            if is_speech:
                in_speech = True                           # Mark as in-speech.
                silence = 0                                # Reset silence counter.
                utt = np.concatenate([utt, chunk])         # Append audio.

                if len(utt) > self.max_utt_frames:         # Force-cut if utterance too long.
                    text = self._transcribe_utt(utt)       # Whisper transcription.
                    if text:
                        yield text                         # Yield recognized text.
                    utt = np.zeros((0,), dtype=np.float32)
                    in_speech = False
                    silence = 0
            else:
                if in_speech:
                    silence += len(chunk)                   # Add silent frames.
                    utt = np.concatenate([utt, chunk])      # Keep a little tail silence for natural endings.
                    if silence >= self.end_silence_frames:
                        if len(utt) >= self.min_speech_frames:
                            text = self._transcribe_utt(utt)
                            if text:
                                yield text
                        utt = np.zeros((0,), dtype=np.float32)
                        in_speech = False
                        silence = 0

    def _transcribe_utt(self, audio_1d: np.ndarray) -> str:
        t0 = perf_counter()               # Start timer (seconds).
        result = self.asr.transcribe(
            audio_1d,                     # 1D float32 audio array (samples).
            language="en",                # Force English.
            fp16=False,                   # Disable fp16 (often more stable on CPU).
            beam_size=1,                  # Beam search width (1 = fast).
            best_of=1,                    # Number of candidates (1 = fast).
            temperature=0.0,              # 0 => deterministic.
            condition_on_previous_text=False, # Don't condition on previous utterances (avoid drift).
            verbose=False,                # Reduce console output.
        )
        self.last_asr_ms = (perf_counter() - t0) * 1000.0 # Store ASR time in milliseconds.
        return (result.get("text") or "").strip()         # Return recognized text (trimmed).


