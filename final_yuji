def load_json(path: str):
    with open(path, "r", encoding="utf-8") as f:
        return json.load(f) # Load JSON into Python dict/list.


def _format_template(s: str, heard_text: str, total_moved: float) -> str:
    try:
        return s.format(heard_text=heard_text, total_moved=total_moved)
# Fill template placeholders like {heard_text}, {total_moved}.
    except Exception:
        return s        # If formatting fails, return original string.


def _play_beep_sequence(seq, sr=BEEP_SR, volume=BEEP_VOLUME):
    """
    seq: [[freq, ms], ...] # freq [Hz], duration [ms]
    """
    out = []
    for item in (seq or []):
        try:
            freq, ms = float(item[0]), float(item[1]) # Parse frequency [Hz] and duration [ms].
        except Exception:
            continue
        n = int(sr * (ms / 1000.0))                # Samples = sr [samples/s] * duration [s].
        t = np.arange(n, dtype=np.float32) / sr    # Time axis [s].
        tone = (np.sin(2.0 * np.pi * freq * t) * volume).astype(np.float32) # Generate sine wave beep (amplitude scaled by volume).
        out.append(tone)
        out.append(np.zeros(int(sr * 0.02), dtype=np.float32))  # Add a 20 ms silence gap between tones.

    if not out:
        return

    y = np.concatenate(out)        # Concatenate all tones + gaps.
    sd.play(y, sr, blocking=True)  # Play audio, blocking until finished.


class TTSEngine:
    """
      Most stable TTS priority:
      1) OS TTS commands (espeak/spd-say/say/PowerShell SAPI)
      2) pyttsx3: init -> runAndWait -> stop every call (do NOT reuse)
      3) last resort: print
    """
    def __init__(self):
        self.system = platform.system().lower()  # OS name in lowercase.
        self.backend = self._detect_backend()    # Choose available TTS backend.
        print(f"[TTS] backend={self.backend}")   # Show chosen backend.

    def _detect_backend(self) -> str:
        # Linux: espeak -> spd-say
        if "linux" in self.system:
            if shutil.which("espeak"):
                return "espeak"
            if shutil.which("spd-say"):
                return "spd-say"
            # fallback to pyttsx3
            return "pyttsx3"

        # macOS
        if "darwin" in self.system:
            if shutil.which("say"):
                return "say"
            return "pyttsx3"

        # Windows
        if "windows" in self.system:
            # PowerShell is usually available
            return "powershell"     # Use PowerShell to invoke Windows SAPI.

        return "pyttsx3"

    def speak(self, text: str):
        text = (text or "").strip()
        if not text:
            return

        try:
            if self.backend == "espeak":
                # -s speed, -v voice (en)
                subprocess.run(["espeak", "-v", "en", "-s", "170", text], check=False)
                return

            if self.backend == "spd-say":
                subprocess.run(["spd-say", "-l", "en", text], check=False)
                return

            if self.backend == "say":
                subprocess.run(["say", text], check=False)
                return

            if self.backend == "powershell":
                # Windows SAPI via PowerShell (quote-safe)
                safe = text.replace("'", "''")  # Escape single quotes for PowerShell.
                ps = (
                    "Add-Type -AssemblyName System.Speech; "
                    "$speak = New-Object System.Speech.Synthesis.SpeechSynthesizer; "
                    f"$speak.Speak('{safe}');"
                )
                subprocess.run(["powershell", "-NoProfile", "-Command", ps], check=False)
                return

            if self.backend == "pyttsx3":
                try:
                    import pyttsx3  # type: ignore
                    engine = pyttsx3.init()   # Key idea: create a fresh engine every time.
                    engine.say(text)
                    engine.runAndWait()
                    engine.stop()
                    return
                except Exception as e:
                    print("[TTS] pyttsx3 failed:", repr(e))
                    print("[TTS]", text)
                    return

        except Exception as e:
            print("[TTS] speak failed:", repr(e))
            print("[TTS]", text)


class IntentResponder:
    """
    intent_responses_en.json 정책대로 응답:
      - mode: tts | beep | silent
      - texts: string or list (random pick)
      - beep: [[freq, ms], ...]
    """
    def __init__(self, cfg: dict):
        self.cfg = cfg or {}                    # Store config (fallback to empty dict).
        self.meta = self.cfg.get("_meta", {})   # Optional meta info.
        self.tts = TTSEngine()                  # Initialize TTS engine.

    def _pick(self, intent: str, heard_text: str, total_moved: float) -> Tuple[Optional[str], Optional[str], dict]:
        item = self.cfg.get(intent, None)       # Policy entry for the given intent.
        if not item:
            return None, None, {}               # No policy => no response.

        mode = (item.get("mode") or "silent").lower() # Default mode is silent.
        texts = item.get("texts", None)               # Response text(s).

        text = None
        if isinstance(texts, list) and texts:
            text = random.choice(texts)              # Randomly pick one.
        elif isinstance(texts, str):
            text = texts                             # Single string.

        if isinstance(text, str):
            text = _format_template(text, heard_text=heard_text, total_moved=total_moved)
                                         # Apply template formatting.
        return mode, text, item          # Return mode, selected text, and raw policy item.

    def respond(self, intent: str, heard_text: str, state: dict, listener: Optional[RealtimeWhisper]):
        intent = (intent or "").upper()                           # Normalize intent key to uppercase.
        total_moved = float(state.get("total_moved", 0.0) or 0.0) # Pull total moved distance from state (typically [m]).

        mode, text, item = self._pick(intent, heard_text, total_moved)
        if not mode:
            return {"mode": None, "text": None}

        # Hard stop/start mic input while producing audio output (beep/TTS).
        if listener is not None and mode in ("tts", "beep"):
            listener.pause_input_stream() # Stop mic input to prevent feedback/crosstalk.
            try:
                if mode == "beep":
                    _play_beep_sequence(item.get("beep"))
                elif mode == "tts":
                    if text:
                        self.tts.speak(text)
            finally:
                time.sleep(0.03)                # Small stabilization delay [s] (= 30 ms).
                listener.resume_input_stream()  # Restart mic input.
        else:
            if mode == "beep":
                _play_beep_sequence(item.get("beep"))
            elif mode == "tts":
                if text:
                    self.tts.speak(text)

        return {"mode": mode, "text": text}     # Return what was actually done (useful for logging/debug).
