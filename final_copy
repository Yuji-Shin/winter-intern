def load_intent_bank(path: str):
    return load_json(path)
#just for record

def override_safety(text: str):
    t = text.lower() # change all input to small letter : input normalization to standardized output
    if any(k in t for k in PAIN_KEYWORDS):
        return "PAIN"
    if any(k in t for k in STOP_KEYWORDS):
        return "STOP"
    if any(k in t for k in START_KEYWORDS):
        return "START"
    return None
# determines whether to activate the override system (pain, stop, start) 

def extract_distance_m(text: str, default_m: float = 0.05) -> float:
    t = text.lower() # input normalization to standardized output
    m = re.search(r"(\d+(\.\d+)?)\s*(mm|millimeter|millimeters)", t)
    if m:
        return max(0.0, float(m.group(1)) / 1000.0)
    m = re.search(r"(\d+(\.\d+)?)\s*(cm|centimeter|centimeters)", t)
    if m:
        return max(0.0, float(m.group(1)) / 100.0)
    m = re.search(r"(\d+(\.\d+)?)\s*(m|meter|meters)", t)
    if m:
        return max(0.0, float(m.group(1)))
    return default_m
# identifie distance-related text and standardizes the units into meters to enable rule-based command interpretation that related to prase_move_command function

def parse_move_command(text: str):
    """
   Parses rule-based movement commands such as 'move up 5 cm'.
   Returns (dx, dy, dz) if successful; otherwise, returns None.
    """
    t = text.lower()  # input normalization to standardized output

    found_dir = None # stores the specific direction keyword from user input, initialzation first
    for w in DIR_WORDS.keys():
        if re.search(rf"\b{re.escape(w)}\b", t):
            found_dir = w
            break
    if not found_dir:
        return None

    has_move_verb = any(re.search(rf"\b{re.escape(v)}\b", t) for v in MOVE_VERBS)
    if not has_move_verb:
        return None

    axis, sign = DIR_WORDS[found_dir]
    dist_m = extract_distance_m(t, default_m=0.05)

    dx = dy = dz = 0.0 # stores the distance the robot needs to move
    if axis == "x":
        dx = sign * dist_m
    elif axis == "y":
        dy = sign * dist_m
    else:
        dz = sign * dist_m
    # Converting commands into robot-understandable vectors

    return dx, dy, dz


def clamp_pose_xyz(pose):
    pose[0] = float(np.clip(pose[0], XYZ_LIMITS["x"][0], XYZ_LIMITS["x"][1]))
    pose[1] = float(np.clip(pose[1], XYZ_LIMITS["y"][0], XYZ_LIMITS["y"][1]))
    pose[2] = float(np.clip(pose[2], XYZ_LIMITS["z"][0], XYZ_LIMITS["z"][1]))
    return pose
# constrain coordinates to stay within the XYZ limits

def safe_stop(rtde_c):
    try:
        rtde_c.stopL(2.0) #liner stop, more complex process
        return True
    except Exception:
        try:
            rtde_c.stopJ(2.0) # joint stop
            return True
        except Exception:
            return False
# Fail-safe mechanism for emergency stopping


def moveL_delta(rtde_c, rtde_r, dx, dy, dz, speed, acc):
    pose = rtde_r.getActualTCPPose() # read robot current location
    print("current TCP pose:", pose)

    target = pose.copy()
    target[0] += float(dx)
    target[1] += float(dy)
    target[2] += float(dz)
    target = clamp_pose_xyz(target) # prevent the robot from exceeding a specified limit within the function

    # real robot moved-distance (reflected clamp)
    adx = float(target[0] - pose[0])
    ady = float(target[1] - pose[1])
    adz = float(target[2] - pose[2])
    moved_dist = math.sqrt(adx * adx + ady * ady + adz * adz)

    print("target  TCP pose:", target)

    if DRY_RUN:
        print("[DRY_RUN] skip moveL")
        return True, moved_dist

    ok = rtde_c.moveL(target, speed, acc) # if moving was successed: True, moving was failed: False
    return ok, moved_dist


def handle_intent(intent: str, rtde_c, rtde_r, state):
    """
    intent -> changing robot moving output/state
    state: dict (armed, speed_scale, total_moved)
    """
    intent = (intent or "").upper() # convert input to capital letters : normalization
    moved = 0.0
    ok = True # default vaule, it can be changed in moveL_delta function 

    if intent == "STOP":
        print("[INTENT] STOP -> stopping + disarming")
        safe_stop(rtde_c)
        state["armed"] = False  # system unarmed
        return {"ok": True, "moved": 0.0}
        # override keyword

    if intent == "START":
        state["armed"] = True # system armed
        print("[INTENT] START -> ARMED=True")
        return {"ok": True, "moved": 0.0}

    if intent == "PAIN":
        print("[INTENT] PAIN -> stop + retract(up) + disarm")
        safe_stop(rtde_c)
        time.sleep(0.1) # Wait for the robot to come to a full stop
        retract_speed = BASE_SPEED * 0.5
        retract_acc = BASE_ACC * 0.5 # Cut to half the existing speed and set it to move away safely
        ok, moved = moveL_delta(rtde_c, rtde_r, 0.0, 0.0, +PAIN_RETRACT_Z_M, retract_speed, retract_acc) # No changes in x and y axes, only changes in z-axis exist
        print("retract ok:", ok) # The variable ok stores whether the robot moved properly (true: success, false: failure)
        state["armed"] = False # system unarmed
        return {"ok": ok, "moved": moved}
        # override keyword

    if intent == "MOVE_SLOW":
        state["speed_scale"] = 0.5
        print("[INTENT] MOVE_SLOW -> speed_scale=0.5")
        return {"ok": True, "moved": 0.0}
        #speed scale covert to 0.5

    if intent == "OK":
        state["speed_scale"] = 1.0
        print("[INTENT] OK -> speed_scale=1.0")
        return {"ok": True, "moved": 0.0}
        # speed scale maintain 

    if intent == "EXPLAIN":
        print("[INTENT] EXPLAIN")
        return {"ok": True, "moved": 0.0}
        # There is no movement change.

    print("[INTENT] Unknown/Unhandled:", intent)
    return {"ok": False, "moved": 0.0}
    # This is the case that MiniLM didn't catch any intent.


def top3_str(candidates):
    try:
        return " | ".join([f"{c['intent']}:{c['score']:.3f}" for c in candidates[:3]]) # Retrieve the top 3 intents
    except Exception:
        return ""


# ======================
# main (REALTIME)
# ======================
def main():
    metrics = None # for csv file
    listener = None # Variable to store the Whisper model for real-time speech recognition
    rtde_c = None
    rtde_r = None

    try:
        metrics_path = os.path.join("logs", f"metrics_{datetime.now():%Y%m%d_%H%M%S}.csv")
        metrics = MetricsCSV(metrics_path)
        metrics.log(kind="startup", step="start", duration_ms=0, note=f"csv={metrics_path}") # making csv file

        print("[ASR] Loading Whisper:", WHISPER_MODEL)
        t0 = perf_counter() # Processing time measurement for CSV file
        asr = whisper.load_model(WHISPER_MODEL) # load whisper
        metrics.log(kind="startup", step="load_whisper", duration_ms=(perf_counter() - t0) * 1000.0, note=WHISPER_MODEL)

        print("[NLU] Loading intent bank + MiniLM retriever/router...")
        t0 = perf_counter()
        intent_bank = load_intent_bank(INTENT_BANK_PATH)
        metrics.log(kind="startup", step="load_intent_bank", duration_ms=(perf_counter() - t0) * 1000.0, note=INTENT_BANK_PATH)

        t0 = perf_counter()
        retriever = MiniLMRetriever(intent_bank) # load MiniLM
        router = IntentRouter(retriever, threshold=THRESHOLD) # load router
        metrics.log(kind="startup", step="init_minilm_router", duration_ms=(perf_counter() - t0) * 1000.0, note=f"threshold={THRESHOLD}")

        print("[RESP] Loading intent responses:", INTENT_RESPONSES_PATH)
        t0 = perf_counter()
        resp_cfg = load_json(INTENT_RESPONSES_PATH) 
        responder = IntentResponder(resp_cfg)
        metrics.log(kind="startup", step="load_intent_responses", duration_ms=(perf_counter() - t0) * 1000.0, note=INTENT_RESPONSES_PATH)

        print("[RTDE] Connecting to:", HOST)
        t0 = perf_counter()
        rtde_c = rtde_control.RTDEControlInterface(HOST)
        rtde_r = rtde_receive.RTDEReceiveInterface(HOST) # connecting to robot system
        metrics.log(kind="startup", step="connect_rtde", duration_ms=(perf_counter() - t0) * 1000.0, note=HOST)

        state = {"armed": False, "speed_scale": 1.0, "total_moved": 0.0}

        print("\nRealtime listening... (Ctrl+C to quit)\n"
              "- Say 'start' to arm\n"
              "- Say 'stop' to stop+disarm\n"
              "- Say 'it hurts' to trigger PAIN behavior\n"
              "- Try: 'move up 5 cm', 'move forward 10 centimeters'\n")

        listener = RealtimeWhisper(asr, sample_rate=SAMPLE_RATE, input_device=INPUT_DEVICE)
        listener.start() # start real time listening

        utt_id = 0 # Variable to assign an index to each user utterance

        for text in listener.listen_texts():
            utt_id += 1
            asr_ms = float(getattr(listener, "last_asr_ms", 0.0) or 0.0)

            print("[TEXT]", text if text else "(empty)")
            if not text:
                metrics.log(kind="utterance", step="empty_text", utt_id=utt_id, duration_ms=0, asr_ms=asr_ms, text="")
                continue

# Command execution priority:
# Safety keyword override → Rule-based move parsing (if available) → MiniLM intent routing
            # 1) Safety keyword override has the highest priority (ultra-low latency)
            t0 = perf_counter()
            ov = override_safety(text)
            ov_ms = (perf_counter() - t0) * 1000.0

            if ov:
                t1 = perf_counter()
                res = handle_intent(ov, rtde_c, rtde_r, state)
                act_ms = (perf_counter() - t1) * 1000.0
                state["total_moved"] += float(res.get("moved", 0.0) or 0.0)

                r = responder.respond(ov, heard_text=text, state=state, listener=listener)

                metrics.log(
                    kind="utterance",
                    step="override",
                    utt_id=utt_id,
                    duration_ms=f"{ov_ms:.3f}",
                    asr_ms=f"{asr_ms:.3f}",
                    text=text,
                    override_intent=ov,
                    chosen_intent=ov,
                    note=f"action_ms={act_ms:.3f}, armed={state['armed']}, speed_scale={state['speed_scale']}, resp_mode={r.get('mode')}"
                )
                print("[STATE]", state, "\n")
                continue

            # 2) 규칙 기반 move 파싱이 되면 그걸 먼저 실행
            t0 = perf_counter()
            delta = parse_move_command(text)
            parse_ms = (perf_counter() - t0) * 1000.0

            if delta:
                if not state["armed"]:
                    metrics.log(
                        kind="utterance",
                        step="rule_move_blocked_not_armed",
                        utt_id=utt_id,
                        duration_ms=f"{parse_ms:.3f}",
                        asr_ms=f"{asr_ms:.3f}",
                        text=text,
                        chosen_intent="RULE_MOVE",
                        note="blocked:not_armed"
                    )
                    print("[BLOCKED] Not armed. Say 'start' first.\n")
                    continue

                dx, dy, dz = delta
                speed = BASE_SPEED * state["speed_scale"]
                acc = BASE_ACC * state["speed_scale"]
                print(f"[RULE_MOVE] dx={dx:.3f}, dy={dy:.3f}, dz={dz:.3f}  speed={speed:.3f}")

                t1 = perf_counter()
                ok, moved = moveL_delta(rtde_c, rtde_r, dx, dy, dz, speed, acc)
                move_ms = (perf_counter() - t1) * 1000.0
                state["total_moved"] += float(moved or 0.0)

                r = responder.respond("RULE_MOVE", heard_text=text, state=state, listener=listener)

                metrics.log(
                    kind="utterance",
                    step="rule_move",
                    utt_id=utt_id,
                    duration_ms=f"{move_ms:.3f}",
                    asr_ms=f"{asr_ms:.3f}",
                    text=text,
                    chosen_intent="RULE_MOVE",
                    note=f"parse_ms={parse_ms:.3f}, ok={ok}, moved={moved:.4f}m, speed={speed:.3f}, resp_mode={r.get('mode')}"
                )

                print("moveL ok:", ok, "\n")
                continue

            # 3) MiniLM intent 라우팅
            t0 = perf_counter()
            chosen, candidates = router.route(text)
            route_ms = (perf_counter() - t0) * 1000.0
            top3 = top3_str(candidates)

            print("\n[Top-3 candidates]")
            for c in candidates[:3]:
                print(f"- {c['intent']:10s} score={c['score']:.3f} ({c['text']})")

            if not chosen:
                metrics.log(
                    kind="utterance",
                    step="route_no_intent",
                    utt_id=utt_id,
                    duration_ms=f"{route_ms:.3f}",
                    asr_ms=f"{asr_ms:.3f}",
                    text=text,
                    top3=top3,
                    note="below_threshold"
                )
                print("\n[NO_INTENT] below threshold\n")
                continue

            intent = chosen["intent"]
            score = chosen.get("score", "")

            print("\n[CHOSEN]", chosen)

            # PAIN/STOP/START 같은 안전 intent는 armed 여부와 관계 없이 처리
            if intent in ["PAIN", "STOP", "START"]:
                t1 = perf_counter()
                res = handle_intent(intent, rtde_c, rtde_r, state)
                act_ms = (perf_counter() - t1) * 1000.0
                state["total_moved"] += float(res.get("moved", 0.0) or 0.0)

                r = responder.respond(intent, heard_text=text, state=state, listener=listener)

                metrics.log(
                    kind="utterance",
                    step="route_intent_safety",
                    utt_id=utt_id,
                    duration_ms=f"{route_ms:.3f}",
                    asr_ms=f"{asr_ms:.3f}",
                    text=text,
                    chosen_intent=intent,
                    chosen_score=score,
                    top3=top3,
                    note=f"action_ms={act_ms:.3f}, armed={state['armed']}, speed_scale={state['speed_scale']}, resp_mode={r.get('mode')}"
                )

                print("[STATE]", state, "\n")
                continue

            # 나머지는 start(armed) 이후에만 실행
            if not state["armed"]:
                metrics.log(
                    kind="utterance",
                    step="route_intent_blocked_not_armed",
                    utt_id=utt_id,
                    duration_ms=f"{route_ms:.3f}",
                    asr_ms=f"{asr_ms:.3f}",
                    text=text,
                    chosen_intent=intent,
                    chosen_score=score,
                    top3=top3,
                    note="blocked:not_armed"
                )
                print("[BLOCKED] Not armed. Say 'start' first.\n")
                continue

            t1 = perf_counter()
            res = handle_intent(intent, rtde_c, rtde_r, state)
            act_ms = (perf_counter() - t1) * 1000.0
            state["total_moved"] += float(res.get("moved", 0.0) or 0.0)

            r = responder.respond(intent, heard_text=text, state=state, listener=listener)

            metrics.log(
                kind="utterance",
                step="route_intent",
                utt_id=utt_id,
                duration_ms=f"{route_ms:.3f}",
                asr_ms=f"{asr_ms:.3f}",
                text=text,
                chosen_intent=intent,
                chosen_score=score,
                top3=top3,
                note=f"action_ms={act_ms:.3f}, armed={state['armed']}, speed_scale={state['speed_scale']}, resp_mode={r.get('mode')}"
            )

            print("[STATE]", state, "\n")

    except KeyboardInterrupt:
        print("\n[QUIT] Ctrl+C")
        if metrics:
            metrics.log(kind="startup", step="keyboard_interrupt", duration_ms=0)
    except Exception as e:
        print("\n[ERROR]", repr(e))
        if metrics:
            metrics.log(kind="startup", step="exception", duration_ms=0, note=repr(e))
        raise
    finally:
        if listener:
            listener.stop()
        if rtde_c:
            try:
                rtde_c.stopScript()
            except Exception:
                pass
        if metrics:
            metrics.log(kind="startup", step="end", duration_ms=0)
            metrics.close()
        print("[RTDE] Closed")


if __name__ == "__main__":
    main()
