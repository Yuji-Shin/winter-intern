def tcp_connectable(host: str, port: int, timeout_s: float = 1.5) -> bool:
    try:
        with socket.create_connection((host, port), timeout=timeout_s):
            return True
    except Exception:
        return False


def has_keyword(text: str, keywords) -> bool:
    t = text.lower()
    for k in keywords:
        if re.search(rf"\b{re.escape(k)}\b", t):
            return True
    return False


def override_safety(text: str) -> Optional[str]:
    t = text.lower() # change all input to small letter : input normalization to standardized output
    if has_keyword(t, PAIN_KEYWORDS):
        return "PAIN"
    if has_keyword(t, STOP_KEYWORDS):
        return "STOP"
    if has_keyword(t, DISARM_KEYWORDS):
        return "DISARM"
    if has_keyword(t, START_KEYWORDS):
        return "START"
    # determines whether to activate the override system (pain, stop, start) 
    return None


def extract_distance_m_clamped(text: str, default_m: float, max_step_m: float) -> float:
    """
    distance extraction(mm/cm/m) + 0~max_step_m clamp
    """
    t = text.lower() # input normalization to standardized output

    m = re.search(r"(\d+(\.\d+)?)\s*(mm|millimeter|millimeters)\b", t)
    if m:
        val = float(m.group(1)) / 1000.0
        return float(np.clip(val, 0.0, max_step_m))

    m = re.search(r"(\d+(\.\d+)?)\s*(cm|centimeter|centimeters)\b", t)
    if m:
        val = float(m.group(1)) / 100.0
        return float(np.clip(val, 0.0, max_step_m))

    m = re.search(r"(\d+(\.\d+)?)\s*(m|meter|meters)\b", t)
    if m:
        val = float(m.group(1))
        return float(np.clip(val, 0.0, max_step_m))

    return float(np.clip(default_m, 0.0, max_step_m))
    # identifie distance-related text and standardizes the units into meters to enable rule-based command interpretation that related to prase_move_command function


def parse_move_command(
    text: str,
    default_step_m: float,
    max_step_m: float,
    require_move_verb: bool = True,
) -> Optional[Tuple[float, float, float, str, float]]:
    """
    Parses rule-based movement commands such as 'move up 5 cm'.
    Returns (dx, dy, dz, found_dir, dist_m) if successful; otherwise, returns None.
    """
    t = text.lower()

    found_dir = None # stores the specific direction keyword from user input, initialzation first
    for w in DIR_WORDS.keys():
        if re.search(rf"\b{re.escape(w)}\b", t):
            found_dir = w
            break
    if not found_dir:
        return None

    if require_move_verb:
        has_move_verb = any(re.search(rf"\b{re.escape(v)}\b", t) for v in MOVE_VERBS)
        if not has_move_verb:
            return None

    axis, sign = DIR_WORDS[found_dir]
    dist_m = extract_distance_m_clamped(t, default_m=default_step_m, max_step_m=max_step_m)

    dx = dy = dz = 0.0 # stores the distance the robot needs to move
    if axis == "x":
        dx = sign * dist_m
    elif axis == "y":
        dy = sign * dist_m
    else:
        dz = sign * dist_m
    # Converting commands into robot-understandable vectors
    return dx, dy, dz, found_dir, dist_m


def clamp_pose_xyz(pose, xyz_limits):
    pose[0] = float(np.clip(pose[0], xyz_limits["x"][0], xyz_limits["x"][1]))
    pose[1] = float(np.clip(pose[1], xyz_limits["y"][0], xyz_limits["y"][1]))
    pose[2] = float(np.clip(pose[2], xyz_limits["z"][0], xyz_limits["z"][1]))
    return pose
    # constrain coordinates to stay within the XYZ limits

def safe_stop(rtde_c) -> bool:
    try:
        rtde_c.stopL(2.0) # liner stop, more complex process
        return True
    except Exception:
        try:
            rtde_c.stopJ(2.0)  # joint stop
            return True
        except Exception:
            return False
# Fail-safe mechanism for emergency stopping

def moveL_delta(rtde_c, rtde_r, dx, dy, dz, speed, acc, xyz_limits, dry_run: bool):
    pose = rtde_r.getActualTCPPose()  # read robot current location
    print("current TCP pose:", pose)

    target = pose.copy() # current robot location
    target[0] += float(dx) # update robot location
    target[1] += float(dy)
    target[2] += float(dz)
    target = clamp_pose_xyz(target, xyz_limits) # prevent the robot from exceeding a specified limit within the function

    print("target  TCP pose:", target)

    if dry_run:
        print("[DRY_RUN] skip moveL")
        return True

    ok = rtde_c.moveL(target, speed, acc) # Control the actual robot movement. Return whether the command was executed.
    return ok


def handle_intent(
    intent: str,
    rtde_c,
    rtde_r,
    state, # current robot state
    base_speed,
    base_acc,
    pain_retract_z_m, # Z-axis movement distance when the intent is pain.
    xyz_limits,
    dry_run,
    announce: Optional[Callable[[str], None]] = None,
):
    """
   intent → robot action or state change
   state: dictionary containing robot states (e.g., armed, speed_scale, pending_move, ...)
   announce: TTS / briefing announcement function (None if unavailable)
    """
    intent = (intent or "").upper() # input generalization

    if intent in ("STOP", "DISARM"):
        print("[INTENT] STOP/DISARM -> stopping + disarming")
        safe_stop(rtde_c)
        state["armed"] = False # robot system off
        state["pending_move"] = None # Delete the pending command
        if announce:
            announce("Stopping. Disarmed.")
        return

    if intent == "START":
        state["armed"] = True
        print("[INTENT] START -> ARMED=True")
        if announce:
            announce("Armed. Ready.")
        return

    if intent == "PAIN":
        print("[INTENT] PAIN -> stop + retract(up) + disarm")
        if announce:
            announce("Stopping. Retracting. Disarming.")
        safe_stop(rtde_c)
        time.sleep(0.1) # Wait until the robot completely stops

        retract_speed = base_speed * 0.5
        retract_acc = base_acc * 0.5
        ok = moveL_delta(
            rtde_c, rtde_r,
            0.0, 0.0, +pain_retract_z_m,
            retract_speed, retract_acc,
            xyz_limits, dry_run
        )
        print("retract ok:", ok)

        state["armed"] = False
        state["pending_move"] = None
        return

    if intent == "MOVE_SLOW":
        state["speed_scale"] = 0.5
        print("[INTENT] MOVE_SLOW -> speed_scale=0.5")
        if announce:
            announce("Slower speed.")
        return

    if intent == "OK":
        state["speed_scale"] = 1.0
        print("[INTENT] OK -> speed_scale=1.0")
        if announce:
            announce("Normal speed.")
        return

    if intent == "EXPLAIN":
        print("[INTENT] EXPLAIN -> (print) I am moving the tool based on your commands.")
        if announce:
            announce("I will move the tool based on your commands.")
        return

    print("[INTENT] Unknown/Unhandled:", intent)


def top3_str(candidates):
    try:
        return " | ".join([f"{c['intent']}:{c['score']:.3f}" for c in candidates[:3]])
    except Exception:
        return ""
# extract top 3 from 'candidates(list)'


def make_rtde_control(host: str, use_urcap: bool):
    """
    Safely create flags since it may not exist depending on the environment.
    """
    if use_urcap and hasattr(rtde_control, "FLAG_USE_EXT_UR_CAP"): 
    # use_urcap: indicates whether the user chose to use URCap
    # Check if FLAG_USE_EXT_UR_CAP exists in rtde_control.
    # The feature works only if both conditions are satisfied.
        return rtde_control.RTDEControlInterface(host, flags=rtde_control.FLAG_USE_EXT_UR_CAP) # Return the object with URCap activated.
    return rtde_control.RTDEControlInterface(host) # Return the basic object 

