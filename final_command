def _now_iso():
    return datetime.now().isoformat(timespec="milliseconds")


class MetricsCSV:
    def __init__(self, path: str):
        os.makedirs(os.path.dirname(path) or ".", exist_ok=True) # Create directory for the CSV file if it doesn't exist.
        self.path = path                                         # Save the path.
        self.f = open(path, "w", newline="", encoding="utf-8")   # Open csv file.
        self.fields = [
            "ts",    # timestamp
            "kind",  # startup / utterance
            "step",  # load_whisper, connect_rtde, route, rule_move...
            "utt_id",# utterance ID
            "duration_ms", # Total step duration [ms]
            "asr_ms", # Whisper transcription time [ms]
            "text", # Recognized text.
            "override_intent", # Rule based override intent (STOP/START/PAIN)
            "chosen_intent", # Final selected intnet.
            "chosen_score", # Similarity score for chosen intent
            "top3", # Top-3 intent candidates 
            "note", # Extra notes 
        ]
        self.w = csv.DictWriter(self.f, fieldnames=self.fields) # Writer that writes dict rows to CSV.
        self.w.writeheader() # Write header row
        self.f.flush() # Flush to disk.

    def log(self, **row):
        base = {k: "" for k in self.fields}  # Initialize all fields as empty strings.
        base.update(row) # Fill with provided values.
        base["ts"] = base["ts"] or _now_iso() # Auto-fill ts if missing.
        self.w.writerow(base) # Write one CSV row.
        self.f.flush() # Flush immediately. Flush means forcing the buffered data to be written to the file (disk) immediately.

    def close(self):
        try:
            self.f.close()
        except Exception:
            pass # Ignore close errors.


# ======================
# Realtime Whisper helper
# ======================
class RealtimeWhisper:
    """
Continuously receives microphone audio, segments speech based on energy levels,
and sends each utterance to Whisper for transcription.
(Token streaming is not used; instead, near real-time processing at the utterance level.)

If mute_event is set:
  - The callback does not push input into the queue
  - The listen_texts loop also clears the queue/buffer and waits

If asr_busy_event is set:
  - While Whisper is transcribing, new input is not pushed into the queue
    """

    def __init__(
        self,
        asr_model,
        sample_rate=16000, # Audio sample rate [Hz] (= samples per second).
        input_device=None, # sounddevice input device index (int). Use None for default device.
        # command to list the sounddevice/PortAudio device indices: python -c "import sounddevice as sd; print(sd.query_devices())"
        chunk_ms=30, # Audio chunk size [ms] (how often the callback pushes audio).
        energy_threshold=0.012, # RMS(Root Mean Square) energy threshold (unitless, based on float32 amplitude).
        min_speech_sec=0.25, # Minimum speech duration to count as an utterance [s].
        end_silence_sec=0.55, # Silence duration to consider the utterance ended [s].
        max_utt_sec=4.5, # Maximum utterance length [s] (limits latency).
        debug_energy=False, # If True, print RMS values (for tuning).
        language="en",
        mute_event: Optional[threading.Event] = None,
    ):
        self.asr = asr_model  # Whisper model instance.
        self.sr = sample_rate # Sample rate [Hz].
        self.device = input_device # Input device index.

        self.chunk_ms = chunk_ms
        self.energy_threshold = energy_threshold
        self.min_speech_sec = min_speech_sec
        self.end_silence_sec = end_silence_sec
        self.max_utt_sec = max_utt_sec
        self.debug_energy = debug_energy
        self.language = language

        self.mute_event = mute_event
        self.asr_busy_event = threading.Event()   # 추가

        self.q = queue.Queue() # Queue for audio chunks.
        self.stop_event = threading.Event() # Stop flag.

        self.chunk_frames = int(self.sr * (self.chunk_ms / 1000.0))  # Frames per chunk = sr [samples/s] * chunk_seconds.
        self.min_speech_frames = int(self.sr * self.min_speech_sec)  # Minimum utterance length in frames.
        self.end_silence_frames = int(self.sr * self.end_silence_sec) # Silence threshold in frames to end an utterance.
        self.max_utt_frames = int(self.sr * self.max_utt_sec) # Maximum utterance length in frames.

        self._stream = None # sounddevice InputStream handle.
        self.last_asr_ms = 0.0 # Last ASR duration [ms].

    def _audio_cb(self, indata, frames, time_info, status):
        if status:
            print("[AUDIO]", status)

        # Ignore input while TTS is speaking
        if self.mute_event is not None and self.mute_event.is_set():
            return

        # Ignore input while Whisper is transcribing
        if self.asr_busy_event.is_set():
            return

        self.q.put(indata[:, 0].copy())  # Push mono channel (copy) into queue.

    def start(self): # start audio recording
        self.stop_event.clear() # Reset the stop signal 
        # Delete the remaining stop signal since a new recording is starting.
        # Initialize a stream to receive microphone input
        self._stream = sd.InputStream( 
            samplerate=self.sr, # Audio sampling rate (number of samples per second)
            channels=1, # Mono recording (no left–right channel separation)
            dtype="float32", # data type (The most commonly used format for deep learning models)
            blocksize=self.chunk_frames, # Audio buffer size (larger size → slower processing speed)
            device=self.device, # Device number selection for cases where multiple microphones are connected
            callback=self._audio_cb, # Callback function executed whenever the blocksize is filled
        ) 
        self._stream.start()

    def stop(self): # stop audio recording
        self.stop_event.set() # stop signal
        if self._stream: # check if the stream is on
            try:
                self._stream.stop()
            except Exception:
                pass
            try:
                self._stream.close()
            except Exception:
                pass
            self._stream = None

    def _drain_queue(self): # Clearing remaining audio data in the queue
        try:
            while True:
                self.q.get_nowait()
        except queue.Empty:
            pass

    def clear_buffers(self): 
        self._drain_queue() 
# Although the buffer and the queue are technically different, 
# clearing the queue effectively has the same effect as clearing the buffer.

    def listen_texts(self):
        in_speech = False # Determining whether a person is currently speaking
        utt = np.zeros((0,), dtype=np.float32) # Variable for storing speech data
        silence = 0 # Silence duration counter

        while not self.stop_event.is_set():
            # Reset buffer/queue and wait if muted
            if self.mute_event is not None and self.mute_event.is_set():
                in_speech = False
                utt = np.zeros((0,), dtype=np.float32)
                silence = 0
                self._drain_queue()
                time.sleep(0.02)
                continue

            # Retrieving an audio chunk from the queue
            try:
                chunk = self.q.get(timeout=0.2)
            except queue.Empty:
                continue

            # Calculating voice energy
            rms = float(np.sqrt(np.mean(chunk * chunk) + 1e-12))
            if self.debug_energy:
                print(f"[RMS] {rms:.5f}")

            is_speech = rms > self.energy_threshold # Considered as speaking when the energy exceeds the threshold

            if is_speech:
                in_speech = True
                silence = 0
                utt = np.concatenate([utt, chunk])

                if len(utt) > self.max_utt_frames:
                    text = self._transcribe_utt(utt)

                    utt = np.zeros((0,), dtype=np.float32)
                    in_speech = False
                    silence = 0

                    if text:
                        yield text
                        self.clear_buffers()   # clearing queue after utterance processing
            else: # in silence case
                if in_speech: # in case speaking just before
                    silence += len(chunk)
                    utt = np.concatenate([utt, chunk])
                    if silence >= self.end_silence_frames: # Consider the utterance finished when the silence duration exceeds a certain threshold
                        if len(utt) >= self.min_speech_frames:
                            text = self._transcribe_utt(utt) # AI Whisper translation

                            utt = np.zeros((0,), dtype=np.float32)
                            in_speech = False
                            silence = 0

                            if text:
                                yield text
                                self.clear_buffers()   # clearing queue after utterance processing
                        else:
                            utt = np.zeros((0,), dtype=np.float32) # Skip translation if the audio is too short
                            in_speech = False
                            silence = 0

    def _transcribe_utt(self, audio_1d: np.ndarray) -> str: # Call Whisper
        self.asr_busy_event.set() # Notification that Whisper is translating
        self._drain_queue()   # Removing stale audio before transcription

        try:
            t0 = perf_counter()
            result = self.asr.transcribe(
                audio_1d,
                language=self.language,
                fp16=False,
                beam_size=1,
                best_of=1,
                temperature=0.0, # Only transcribe audible audio
                condition_on_previous_text=False,
                verbose=False,
            ) # Tuned for minimal latency rather than accuracy
            self.last_asr_ms = (perf_counter() - t0) * 1000.0
            return (result.get("text") or "").strip()
        finally:
            self._drain_queue()   # Removing audio received during transcription
            self.asr_busy_event.clear()


